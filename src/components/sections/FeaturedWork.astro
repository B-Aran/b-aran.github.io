---
import { getCollection } from 'astro:content';

const allFeatured = await getCollection('featured');
const projects = allFeatured.sort((a, b) => a.data.order - b.data.order);
---

<section id="work" data-reveal>
  <h2 class="section-heading">
    <span class="section-num">03.</span> Some Things I've Built
  </h2>

  <div class="featured-list">
    {projects.map((project, i) => {
      const isEven = i % 2 === 0;
      return (
        <div class:list={['featured-item', { reverse: !isEven }]}>
          <div class="featured-img-wrapper">
            {project.data.cover
              ? <img src={project.data.cover} alt={project.data.title} class="featured-img" loading="lazy" />
              : <div class="featured-img-placeholder" />
            }
          </div>

          <div class:list={['featured-content', { 'content-right': isEven, 'content-left': !isEven }]}>
            <p class="featured-overline">Featured Project</p>
            <h3 class="featured-title">
              {project.data.external
                ? <a href={project.data.external} target="_blank" rel="noopener noreferrer">{project.data.title}</a>
                : project.data.title
              }
            </h3>
            <div class="featured-description">
              <p>{project.data.description}</p>
            </div>
            <ul class="featured-tech">
              {project.data.tech.map(t => <li>{t}</li>)}
            </ul>
            <div class="featured-links">
              {project.data.github && (
                <a href={project.data.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
                  <svg xmlns="http://www.w3.org/2000/svg" role="img" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><title>GitHub</title><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                </a>
              )}
              {project.data.external && (
                <a href={project.data.external} target="_blank" rel="noopener noreferrer" aria-label="External link">
                  <svg xmlns="http://www.w3.org/2000/svg" role="img" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><title>External Link</title><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                </a>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  #work {
    max-width: 900px;
    margin: 0 auto;
    padding: 100px 0;
  }

  .section-heading {
    display: flex;
    align-items: center;
    font-size: clamp(26px, 5vw, 32px);
    font-weight: 600;
    color: var(--lightest-slate);
    white-space: nowrap;
    margin-bottom: 50px;
  }

  .section-heading::after {
    content: '';
    display: block;
    height: 1px;
    width: 300px;
    background-color: var(--lightest-navy);
    margin-left: 20px;
    flex-shrink: 1;
  }

  .section-num {
    font-family: var(--font-mono);
    font-size: clamp(var(--fz-md), 3vw, var(--fz-xl));
    color: var(--green);
    margin-right: 10px;
  }

  .featured-list {
    display: flex;
    flex-direction: column;
    gap: 100px;
  }

  .featured-item {
    position: relative;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    align-items: center;
  }

  .featured-img-wrapper {
    grid-column: 1 / 8;
    grid-row: 1;
    position: relative;
    z-index: 1;
  }

  .featured-item.reverse .featured-img-wrapper {
    grid-column: 6 / 13;
  }

  .featured-img,
  .featured-img-placeholder {
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: var(--border-radius);
    filter: grayscale(20%) brightness(90%);
    transition: var(--transition);
  }

  .featured-img-placeholder {
    background: linear-gradient(135deg, var(--lightest-navy) 0%, var(--light-navy) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .featured-img-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background-color: var(--green-tint);
    border-radius: var(--border-radius);
    z-index: 2;
    transition: var(--transition);
  }

  .featured-item:hover .featured-img-wrapper::after {
    background-color: transparent;
  }

  .featured-item:hover .featured-img {
    filter: none;
  }

  .featured-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .content-right {
    grid-column: 7 / 13;
    grid-row: 1;
    align-items: flex-end;
    text-align: right;
  }

  .content-left {
    grid-column: 1 / 7;
    grid-row: 1;
    align-items: flex-start;
    text-align: left;
  }

  .featured-overline {
    font-family: var(--font-mono);
    font-size: var(--fz-xs);
    color: var(--green);
    margin-bottom: 10px;
  }

  .featured-title {
    font-size: clamp(var(--fz-md), 5vw, 28px);
    font-weight: 600;
    color: var(--lightest-slate);
    margin-bottom: 25px;
    line-height: 1.1;
  }

  .featured-title a {
    color: inherit;
    text-decoration: none;
  }

  .featured-title a:hover {
    color: var(--green);
  }

  .featured-description {
    background-color: var(--light-navy);
    padding: 25px;
    border-radius: var(--border-radius);
    box-shadow: 0 10px 30px -15px var(--navy-shadow);
    margin-bottom: 25px;
  }

  .featured-description p {
    color: var(--light-slate);
    font-size: var(--fz-lg);
    line-height: 1.6;
    margin: 0;
  }

  .featured-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    list-style: none;
    padding: 0;
    margin-bottom: 10px;
  }

  .content-right .featured-tech {
    justify-content: flex-end;
  }

  .featured-tech li {
    font-family: var(--font-mono);
    font-size: var(--fz-xs);
    color: var(--slate);
  }

  .featured-links {
    display: flex;
    gap: 15px;
    margin-top: 10px;
  }

  .featured-links a {
    color: var(--lightest-slate);
    transition: var(--transition);
  }

  .featured-links a:hover {
    color: var(--green);
  }

  @media (max-width: 768px) {
    .featured-list {
      gap: 70px;
    }

    .featured-item,
    .featured-item.reverse {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .featured-img-wrapper,
    .featured-item.reverse .featured-img-wrapper {
      width: 100%;
    }

    .featured-content,
    .content-right,
    .content-left {
      padding: 25px;
      background-color: var(--light-navy);
      border-radius: 0 0 var(--border-radius) var(--border-radius);
      width: 100%;
      align-items: flex-start;
      text-align: left;
    }

    .featured-description {
      background: none;
      padding: 0;
      box-shadow: none;
      margin-bottom: 15px;
    }

    .content-right .featured-tech {
      justify-content: flex-start;
    }

    .featured-img-wrapper::after {
      display: none;
    }
  }
</style>
