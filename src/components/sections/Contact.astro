---
import { siteConfig } from '@/config';
---

<section id="contact" data-reveal>
  <p class="contact-overline">04. What's Next?</p>
  <h2 class="contact-title">Get In Touch.</h2>
  <p class="contact-description">
    Whether you have a question, a project idea, or just want to say hello —
    my inbox is open. I'll do my best to get back to you.
  </p>
  <a href={`mailto:${siteConfig.email}`} class="btn">Say Hello</a>
</section>

<style>
  #contact {
    max-width: 600px;
    margin: 0 auto;
    padding: 100px 0 200px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .contact-overline {
    font-family: var(--font-mono);
    font-size: var(--fz-md);
    color: var(--green);
    margin-bottom: 20px;
  }

  .contact-title {
    font-size: clamp(40px, 5vw, 60px);
    font-weight: 600;
    color: var(--lightest-slate);
    margin-bottom: 20px;
    line-height: 1.1;
  }

  .contact-description {
    color: var(--slate);
    font-size: var(--fz-lg);
    line-height: 1.6;
    margin-bottom: 50px;
    max-width: 480px;
  }

  .btn {
    display: inline-block;
    color: var(--green);
    border: 1px solid var(--green);
    border-radius: var(--border-radius);
    padding: 1.25rem 1.75rem;
    font-family: var(--font-mono);
    font-size: var(--fz-sm);
    line-height: 1;
    text-decoration: none;
    transition: var(--transition);
  }

  .btn:hover {
    background-color: var(--green-tint);
  }
</style>
